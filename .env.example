# Copy this file to .env and fill in real values. Never commit .env.

# LambdaTest credentials
LT_USERNAME=your_username_here
LT_EMAIL=your_email@example.com
LT_PASSWORD=your_password_here
LT_ACCESS_KEY=your_access_key_here

# Base URLs (defaults shown — override only if needed)
LT_BASE_URL=https://test-manager.lambdatest.com
LT_API_BASE_URL=https://api.lambdatest.com/automation/api/v1
