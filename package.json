{
  "name": "testmu-sdet2-kugarg",
  "version": "1.0.0",
  "description": "Playwright + TypeScript test framework (UI, API, integration) for LambdaTest Test Manager",
  "private": true,
  "scripts": {
    "test": "playwright test --project=chromium",
    "test:smoke": "playwright test --grep @smoke",
    "test:api": "playwright test tests/api",
    "test:ui": "playwright test tests/ui --project=chromium",
    "test:integration": "playwright test tests/integration --project=chromium",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "typescript",
    "sdet",
    "test-automation"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.0",
    "allure-playwright": "^2.15.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.4.0"
  }
}
